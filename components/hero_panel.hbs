<section class="hero-panel hero-panel-large">
    <img src="https://picsum.photos/id/{{hero-bg}}/1200/600" alt="Hero" class="hero-bg-img" />
    <div class="hero-content">
        <h1>{{hero-title}}</h1>
        <p>{{hero-text}}</p>
        {{#if hero-cta}}
        <a href="{{hero-cta-link}}" class="btn hero-btn">{{hero-cta}}</a>
        {{/if}}
    </div>
</section>